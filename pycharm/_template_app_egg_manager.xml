<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="{APP}_egg gen" type="PythonConfigurationType" factoryName="Python" folder="{APP}">
    <module name="{APP}_project" />
    <option name="ENV_FILES" value="" />
    <option name="INTERPRETER_OPTIONS" value="" />
    <option name="PARENT_ENVS" value="true" />
    <envs>
      <env name="PYTHONUNBUFFERED" value="1" />
      <env name="PROJECT_PATH" value="$PROJECT_DIR$/src/agilab/apps/{APP}_project" />
      <env name="VIRTUAL_ENV" value="$PROJECT_DIR$/src/agilab/apps/{APP}_project/.venv" />
      <env name="PYTHON_EXECUTABLE" value="$PROJECT_DIR$/src/agilab/apps/{APP}_project/.venv/bin/python" />
    </envs>
    <!-- Explicitly bind SDK to this app's venv -->
    <option name="SDK_HOME" value="$PROJECT_DIR$/src/agilab/apps/{APP}_project/.venv/bin/python" />
    <option name="SDK_NAME" value="uv ({APP}_project)" />
    <option name="WORKING_DIRECTORY" value="" />
    <option name="IS_MODULE_SDK" value="false" />
    <option name="ADD_CONTENT_ROOTS" value="true" />
    <option name="ADD_SOURCE_ROOTS" value="true" />
    <EXTENSION ID="PythonCoverageRunConfigurationExtension" runner="coverage.py" />
    <option name="SCRIPT_NAME" value="$PROJECT_DIR$/src/agilab/apps/{APP}_project/build.py" />
    <option name="PARAMETERS" value="bdist_egg --packages &quot;agent_worker, pandas_worker, polars_worker, dag_worker&quot; -d $USER_HOME$/wenv/{APP}_worker" />
    <option name="SHOW_COMMAND_LINE" value="false" />
    <option name="EMULATE_TERMINAL" value="false" />
    <option name="MODULE_MODE" value="false" />
    <option name="REDIRECT_INPUT" value="false" />
    <option name="INPUT_FILE" value="" />
    <method v="2" />
  </configuration>
</component>