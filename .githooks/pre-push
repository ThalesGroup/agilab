#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ "${AGILAB_SKIP_LOCAL_GUARDS:-}" == "1" ]]; then
  echo "[agilab pre-push] AGILAB_SKIP_LOCAL_GUARDS=1; skipping local guards." >&2
  exit 0
fi

cd "$ROOT_DIR"
uv --preview-features extra-build-dependencies run python tools/sync_docs_source.py \
  --verify-stamp \
  --quiet
uv --preview-features extra-build-dependencies run python tools/sync_docs_source.py \
  --check \
  --delete \
  --quiet \
  --skip-missing-source
uv --preview-features extra-build-dependencies run python tools/coverage_badge_guard.py \
  --changed-only \
  --require-fresh-xml
