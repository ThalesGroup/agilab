#!/usr/bin/env python3
"""
AGI app setup
Author: Jean-Pierre Morard
Tested on Windows, Linux and MacOS
"""

import sys
import os
import logging
from pathlib import Path
from zipfile import ZipFile
import argparse
from setuptools import setup, find_packages, Extension, SetuptoolsDeprecationWarning
from Cython.Build import cythonize
from agi_env import AgiEnv
import warnings

warnings.filterwarnings("ignore", category=SetuptoolsDeprecationWarning)

# Configure logging
logging.basicConfig(level=logging.INFO, format="%(levelname)s: %(message)s")


def parse_custom_args(raw_args: list[str]) -> argparse.Namespace:
    """
    Parse custom CLI arguments and return an argparse Namespace.
    Known args:
      - packages: comma-separated list
      - install_type: integer install type
      - build_dir: output directory for build_ext (alias -b)
      - command: setup command ("build_ext" or "bdist_egg")
    Unknown args are left in remaining.
    """
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument(
        'command',
        choices=['build_ext', 'bdist_egg'],
        help='Setup command to run'
    )
    parser.add_argument(
        '--packages', '-p',
        type=lambda s: [pkg.strip() for pkg in s.split(',') if pkg.strip()],
        default=[],
        help='Comma-separated list of extra packages to include'
    )
    parser.add_argument(
        '--install-type', '-i',
        dest='install_type',
        type=int,
        default=1,
        help='Installation type identifier (integer)'
    )
    parser.add_argument(
        '--build-dir', '-b',
        dest='build_dir',
        help='Output directory for build_ext'
    )
    # allow interspersed remaining args for setuptools
    known, remaining = parser.parse_known_args(raw_args)
    known.remaining = remaining
    # Validate required build_dir for build_ext
    if known.command == 'build_ext' and not known.build_dir:
        parser.error("'build_ext' requires --build-dir/-b <out-dir>")
    return known


def truncate_path_at_segment(
        path_str: str, segment: str = "_worker", exact_match: bool = False, multiple: bool = False
) -> Path:
    path = Path(path_str)
    if exact_match:
        indices = [i for i in reversed(range(len(path.parts))) if path.parts[i] == segment]
    else:
        indices = [i for i in reversed(range(len(path.parts))) if segment in path.parts[i]]

    if not indices:
        raise ValueError(
            f"Cannot compile worker extension from '{path_str}' as it does not contain segment '{segment}'."
        )

    target_index = indices[-1] if multiple else indices[0]
    return Path(*path.parts[: target_index + 1])


def find_sys_prefix(base_dir: str) -> str:
    base = Path(base_dir).expanduser()
    python_dirs = sorted(base.glob("Python???"))
    if python_dirs:
        logging.info(f"Found Python directory: {python_dirs[0]}")
        return str(python_dirs[0])
    else:
        return sys.prefix


def create_symlink_for_module(env, pck: str) -> list[Path]:
    dir_pck = pck.replace('.', os.sep)
    root_pck = pck.split(".")[0].split("_")[1]
    src = env.agi_root / 'fwk' / root_pck / "src" / dir_pck
    dest = Path("src") / dir_pck
    created_links: list[Path] = []

    try:
        dest = dest.absolute()
    except FileNotFoundError:
        logging.error(f"Source path does not exist: {src}")
        sys.exit(1)

    if not dest.parent.exists():
        logging.info(f"Creating directory: {dest.parent}")
        dest.parent.mkdir(parents=True, exist_ok=True)

    if not dest.exists():
        logging.info(f"Linking {src} -> {dest}")
        try:
            AgiEnv.create_symlink(src, dest)
            created_links.append(dest)
            logging.info(f"Symlink created: {dest} -> {src}")
        except Exception as symlink_err:
            logging.warning(f"Symlink creation failed: {symlink_err}. Trying hard link instead.")
            try:
                os.link(src, dest)
                created_links.append(dest)
                logging.info(f"Hard link created: {dest} -> {src}")
            except Exception as link_err:
                logging.error(f"Failed to create link from {src} to {dest}: {link_err}")
                sys.exit(1)
    else:
        logging.debug(f"Link already exists for {dest}")

    return created_links


# --- End custom command ---

def main() -> None:
    # Extract custom args
    custom = parse_custom_args(sys.argv[1:])
    # Prepare parameters
    # Reconstruct sys.argv for setuptools: only include the command and its build-dir for build_ext
    sys.argv = [sys.argv[0], custom.command]
    if custom.command == 'build_ext':
        sys.argv += ['-b', custom.build_dir]
    # (we do not forward --packages or --install-type into setuptools)

    # Prepare parameters
    command = custom.command
    packages = custom.packages
    install_type = custom.install_type
    out_dir = custom.build_dir

    try:
        # get extension path from build_dir or assume bdist_egg
        ext_path = truncate_path_at_segment(out_dir or custom.remaining[-1], "_worker")
    except ValueError as e:
        logging.error(e)
        sys.exit(1)

    target_package = ext_path.stem.replace("_worker", "")
    target_module = target_package.replace("-", "_")
    env = AgiEnv(active_app=target_package + "_project", install_type=install_type)

    # Setup modules and extensions
    custom_modules = ["agi_core.workers.agi_worker", "agi_env"] + packages
    worker_module = target_module + '_worker'
    ext_modules = []
    links_created: list[Path] = []

    if command == 'build_ext':
        os.chdir(env.wenv_abs)
        src_path = (env.wenv_abs / 'src' / worker_module / worker_module).with_suffix('.pyx')
        sys_prefix = find_sys_prefix("~/MyApp")
        extension_mod = Extension(
            name=f"{worker_module}_cy",
            sources=[str(src_path.absolute())],
            include_dirs=[str(Path(sys_prefix) / 'include')],
            library_dirs=[str(Path(sys_prefix) / sys.platlibdir)]
        )
        ext_modules = cythonize([extension_mod], language_level=3)
        logging.info(f"Cython extension configured for {worker_module}_cy")
    else:
        os.chdir(env.app_path)
        for module in custom_modules:
            links_created.extend(create_symlink_for_module(env, module))

    discovered = find_packages(where='src', exclude=[target_module, f"{target_module}.*"] )
    all_packages = list(set(discovered + custom_modules))
    logging.info(f"Final package list: {all_packages}")

    wenv_path = Path('~').expanduser() / env.wenv_rel
    sys.argv[-1] = str(wenv_path)

    setup(
        name=worker_module,
        package_dir={'': 'src'},
        packages=all_packages,
        package_data={'': ['*.pyx', '*.7z']},
        ext_modules=ext_modules,
        zip_safe=False,
    )

    if command == 'bdist_egg':
        wenv_path.mkdir(parents=True, exist_ok=True)
        for egg in wenv_path.glob('*.egg'):
            with ZipFile(egg, 'r') as zf:
                zf.extractall(wenv_path / 'src')
        # post-process decorators removal
        script = env.cyprepro
        worker_src = (wenv_path / 'src' / worker_module / worker_module).with_suffix('.py')
        cmd = (
            f"uv run python '{script}' remove_decorators "
            f"--worker_path '{worker_src}' --verbose"
        )
        if env.verbose:
            print(cmd, "\ncwd:", os.getcwd(), "\nfrom:", env.core_root)
        res = env.run(cmd, env.wenv_abs)
        if env.verbose:
            print("stdout:\n", res.get('stdout'))
            print("stderr:\n", res.get('stderr'))
        # cleanup symlinks
        for link in links_created:
            link.unlink()

if __name__ == '__main__':
    main()
