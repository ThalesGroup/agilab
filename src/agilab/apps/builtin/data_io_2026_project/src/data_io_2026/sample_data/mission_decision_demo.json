      "risk": 0.22,
      "bandwidth_mbps": 18.0
    },
    {
      "route_id": "relay_mesh",
      "label": "Relay mesh route",
      "latency_ms": 104.0,
      "cost": 46.0,
      "reliability": 0.96,
      "risk": 0.16,
      "bandwidth_mbps": 12.0
    },
    {
      "route_id": "fallback_store_forward",
