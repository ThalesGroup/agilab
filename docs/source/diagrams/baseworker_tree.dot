digraph BaseWorkerTree {
  rankdir=TB;
  node [shape=box, style=filled, color="#0f172a", fillcolor="#e2e8f0", fontname="Helvetica", fontsize=12];
  edge [color="#475569", penwidth=1.4];

  BaseWorker [label="BaseWorker\n(agi_node)", fillcolor="#c7d2fe", color="#312e81"];
  DagWorker [label="DagWorker\n(algo worker)", fillcolor="#bfdbfe", color="#1d4ed8"];
  PandasWorker [label="PandasWorker\n(data worker)"];  
  PolarsWorker [label="PolarsWorker\n(data worker)"];
  FireducksWorker [label="FireducksWorker\n(data worker)", fillcolor="#fef9c3", color="#eab308"];

  BaseWorker -> DagWorker;
  BaseWorker -> PandasWorker;
  BaseWorker -> PolarsWorker;
  BaseWorker -> FireducksWorker;
}
