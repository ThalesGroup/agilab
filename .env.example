# Core credentials (never commit real values)
OPENAI_API_KEY=__set_me__
AGI_CLUSTER_URL=__set_me__
CLUSTER_CREDENTIALS=__user__:__password__

# App discovery
APPS_DIR=${HOME}/agilab/src/agilab/apps
APP_DEFAULT=flight_project

# Runtime tuning
TABLE_MAX_ROWS=1000
TABLE_SAMPLING=20
AGI_PYTHON_VERSION=3.13.7
AGI_PYTHON_FREE_THREADED=0

# Paths for shared data and logs
AGI_SHARE_DIR=data
AGI_LOG_DIR=${HOME}/log
AGI_EXPORT_DIR=${HOME}/export
MLFLOW_TRACKING_DIR=${HOME}/.mlflow
AGI_PAGES_DIR=agilab/apps-pages

# Install behaviour
INSTALL_TYPE=1
UV_NO_SYNC=1
